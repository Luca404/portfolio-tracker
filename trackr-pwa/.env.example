# ====================================
# Trackr PWA - Configurazione
# ====================================

# Modalità offline (true = usa IndexedDB locale, false = usa server backend)
# Default: true (offline mode)
VITE_OFFLINE_MODE=true

# URL del server backend (usato solo se VITE_OFFLINE_MODE=false)
# Esempio: http://localhost:8000 o https://api.trackr.example.com
VITE_API_URL=http://localhost:8000
